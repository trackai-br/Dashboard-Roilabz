# Inngest
INNGEST_EVENT_KEY=evt_prod_xxx
INNGEST_SIGNING_KEY=xxxx

# Meta API
META_APP_ID=1234567890
META_APP_SECRET=xxx
META_ACCESS_TOKEN=EAAB...
META_SYSTEM_USER_ID=xxx
META_API_VERSION=v23.0

# Meta OAuth
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback
NEXT_PUBLIC_META_APP_ID=1234567890

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# Google OAuth (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# Google Ads API
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_API_DEVELOPER_TOKEN=xxx

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/meta_ads
